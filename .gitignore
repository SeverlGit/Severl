.idea/

# Local AI / editor state (machine paths, API keys in local config)
.claude/
.cursor/

# Accidental local binaries in repo root
claude.exe

# Certificates & private keys
*.pem
*.key
*.p12

# Sentry CLI local auth (if you use sentry-cli outside env vars)
.sentryclirc
